# %% [markdown]
# # 04 - Análisis SQL con DuckDB [citation:4][citation:10]

# %%
import duckdb
import polars as pl

# Cargar datos
movies = pl.read_csv('data/ml-latest-small/movies.csv')
ratings = pl.read_csv('data/ml-latest-small/ratings.csv')

# %%
# Conectar a DuckDB (base de datos en memoria)
conn = duckdb.connect()

# Registrar DataFrames de Polars como tablas virtuales
conn.register('movies', movies.to_pandas())
conn.register('ratings', ratings.to_pandas())

# %%
# Consulta 1: Top películas por calificación promedio (mínimo 50 ratings)
query1 = """
SELECT 
    m.title,
    AVG(r.rating) as avg_rating,
    COUNT(*) as rating_count,
    m.genres
FROM ratings r
JOIN movies m ON r.movieId = m.movieId
GROUP BY m.movieId, m.title, m.genres
HAVING COUNT(*) >= 50
ORDER BY avg_rating DESC
LIMIT 10;
"""

top_rated = conn.execute(query1).fetchdf()
print("🏆 Top 10 películas mejor calificadas (min 50 ratings):")
print(top_rated[['title', 'avg_rating', 'rating_count']])

# %%
# Consulta 2: Análisis por género
query2 = """
WITH genre_exploded AS (
    SELECT 
        unnest(string_split(m.genres, '|')) as genre,
        r.rating,
        r.userId
    FROM movies m
    JOIN ratings r ON m.movieId = r.movieId
)
SELECT 
    genre,
    COUNT(*) as total_ratings,
    AVG(rating) as avg_rating,
    COUNT(DISTINCT userId) as unique_users
FROM genre_exploded
GROUP BY genre
ORDER BY total_ratings DESC;
"""

genre_analysis = conn.execute(query2).fetchdf()
print("\n🎭 Análisis por género:")
print(genre_analysis)

# %%
# Visualizar análisis por género
import plotly.express as px

fig = px.scatter(
    genre_analysis,
    x='total_ratings',
    y='avg_rating',
    size='unique_users',
    text='genre',
    title='Análisis de Géneros: Popularidad vs Calificación',
    labels={'total_ratings': 'Total Ratings', 'avg_rating': 'Calificación Promedio'}
)
fig.update_traces(textposition='top center')
fig.show()
fig.write_image("images/analisis_generos.png")

# %%
# Consulta 3: Distribución de calificaciones por usuario (actividad)
query3 = """
SELECT 
    userId,
    COUNT(*) as rating_count,
    AVG(rating) as user_avg,
    MIN(rating) as min_rating,
    MAX(rating) as max_rating
FROM ratings
GROUP BY userId
ORDER BY rating_count DESC
LIMIT 20;
"""

user_activity = conn.execute(query3).fetchdf()
print("\n👥 Usuarios más activos:")
print(user_activity)

# %%
# Consulta 4: Correlación entre número de ratings y calificación promedio (por película)
query4 = """
WITH movie_stats AS (
    SELECT 
        movieId,
        COUNT(*) as n_ratings,
        AVG(rating) as avg_rating
    FROM ratings
    GROUP BY movieId
)
SELECT 
    CORR(n_ratings, avg_rating) as correlation
FROM movie_stats;
"""

correlation = conn.execute(query4).fetchone()[0]
print(f"\n📈 Correlación entre popularidad y calificación: {correlation:.3f}")
print("(Valores negativos indican que películas muy populares tienden a tener calificaciones más bajas)")
