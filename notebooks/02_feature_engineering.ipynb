# %% [markdown]
# # 02 - Feature Engineering con Polars

# %%
import polars as pl
import numpy as np

# Cargar datos
movies = pl.read_csv('data/ml-latest-small/movies.csv')
ratings = pl.read_csv('data/ml-latest-small/ratings.csv')

# %%
# 1. Extraer año del título [citation:1]
movies = movies.with_columns(
    pl.col('title')
    .str.extract(r'\((\d{4})\)$', 1)
    .alias('year')
    .cast(pl.Int32, strict=False)
)

print("Películas con año extraído:")
print(movies.select(['title', 'year']).head(10))

# %%
# 2. Procesar géneros (separar pipe-separated)
movies = movies.with_columns(
    pl.col('genres').str.split('|').alias('genres_list')
)

# %%
# 3. Crear métricas agregadas por película usando lazy execution [citation:9]
lazy_ratings = ratings.lazy()

movie_stats = (
    lazy_ratings
    .group_by('movieId')
    .agg([
        pl.count().alias('rating_count'),
        pl.mean('rating').alias('avg_rating'),
        pl.std('rating').alias('std_rating'),
        pl.quantile('rating', 0.5).alias('median_rating')
    ])
    .collect()
)

# Unir con movies
movies_with_stats = movies.join(movie_stats, on='movieId', how='left')

print("📊 Estadísticas por película:")
print(movies_with_stats.select(['title', 'rating_count', 'avg_rating']).head(10))

# %%
# 4. Métricas por usuario
user_stats = (
    ratings.lazy()
    .group_by('userId')
    .agg([
        pl.count().alias('user_rating_count'),
        pl.mean('rating').alias('user_avg_rating')
    ])
    .collect()
)

# %%
# 5. Crear matriz usuario-película (para el modelo)
# Versión eficiente con Polars - creamos pivot table
# Primero, obtener top N películas para reducir dimensionalidad
top_movie_ids = (
    movie_stats
    .filter(pl.col('rating_count') >= 10)  # Filtrar películas con al menos 10 ratings
    .sort('rating_count', descending=True)
    .head(1000)  # Top 1000 películas más calificadas
)['movieId'].to_list()

# Filtrar ratings
ratings_filtered = ratings.filter(pl.col('movieId').is_in(top_movie_ids))

# Crear matriz (para el modelo usaremos una versión optimizada)
print(f"✅ Matriz preparada: {ratings_filtered['userId'].n_unique()} usuarios x {len(top_movie_ids)} películas")
