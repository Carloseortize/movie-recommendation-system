# %% [markdown]
# # 01 - Exploración de datos con Polars

# %%
import polars as pl
import plotly.express as px
import plotly.graph_objects as go
from plotly.subplots import make_subplots

# %%
# Cargar datos con Polars [citation:3]
movies = pl.read_csv('data/ml-latest-small/movies.csv')
ratings = pl.read_csv('data/ml-latest-small/ratings.csv')

# %%
# Ver primeras filas
print("🎬 Películas:")
print(movies.head())

print("\n⭐ Calificaciones:")
print(ratings.head())

# %%
# Información básica
print(f"Total películas: {movies.height}")
print(f"Total calificaciones: {ratings.height}")
print(f"Usuarios únicos: {ratings['userId'].n_unique()}")
print(f"Películas calificadas: {ratings['movieId'].n_unique()}")

# %%
# Análisis de calificaciones
rating_stats = ratings.group_by('rating').agg(
    pl.count().alias('count')
).sort('rating')

print("Distribución de calificaciones:")
print(rating_stats)

# %%
# Visualización 1: Distribución de calificaciones
fig1 = px.bar(
    rating_stats.to_pandas(), 
    x='rating', 
    y='count',
    title='Distribución de Calificaciones',
    labels={'rating': 'Calificación', 'count': 'Número de calificaciones'},
    color='count',
    color_continuous_scale='Viridis'
)
fig1.show()
# Guardar para el README
fig1.write_image("images/distribucion_calificaciones.png")

# %%
# Top 10 películas más calificadas
top_movies = ratings.group_by('movieId').agg([
    pl.count().alias('rating_count'),
    pl.mean('rating').alias('avg_rating')
]).join(movies, on='movieId').sort('rating_count', descending=True).head(10)

print("🎥 Top 10 películas más calificadas:")
print(top_movies.select(['title', 'rating_count', 'avg_rating']))

# %%
# Visualización 2: Top películas
fig2 = px.bar(
    top_movies.to_pandas(),
    x='title',
    y='rating_count',
    title='Top 10 Películas Más Calificadas',
    labels={'title': 'Película', 'rating_count': 'Número de calificaciones'},
    color='avg_rating',
    color_continuous_scale='Plasma'
)
fig2.update_layout(xaxis_tickangle=-45)
fig2.show()
fig2.write_image("images/top_peliculas.png")

# %%
# Análisis de usuarios activos
active_users = ratings.group_by('userId').agg([
    pl.count().alias('ratings_count'),
    pl.mean('rating').alias('avg_user_rating')
]).sort('ratings_count', descending=True)

print("👤 Usuarios más activos:")
print(active_users.head(10))

# %%
# Distribución de actividad de usuarios
fig3 = px.histogram(
    active_users.to_pandas(),
    x='ratings_count',
    nbins=50,
    title='Distribución de Actividad de Usuarios',
    labels={'ratings_count': 'Número de calificaciones por usuario'}
)
fig3.show()
fig3.write_image("images/actividad_usuarios.png")
