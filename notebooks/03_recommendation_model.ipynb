# %% [markdown]
# # 03 - Modelo de Recomendación (Item-Based Collaborative Filtering)

# %%
import polars as pl
import numpy as np
from sklearn.metrics.pairwise import cosine_similarity
import pandas as pd

# Cargar datos
movies = pl.read_csv('data/ml-latest-small/movies.csv')
ratings = pl.read_csv('data/ml-latest-small/ratings.csv')

# %%
# Preparar datos para el modelo
# Obtener películas con suficientes ratings
movie_stats = ratings.group_by('movieId').agg(
    pl.count().alias('rating_count')
).filter(pl.col('rating_count') >= 20)  # Umbral mínimo

popular_movies = movie_stats['movieId'].to_list()
ratings_filtered = ratings.filter(pl.col('movieId').is_in(popular_movies))

# %%
# Crear matriz usuario-película (convertir a pandas para scikit-learn) [citation:6]
ratings_pd = ratings_filtered.to_pandas()

# Pivot table
user_movie_matrix = ratings_pd.pivot_table(
    index='userId', 
    columns='movieId', 
    values='rating'
).fillna(0)

print(f"Matriz dimensión: {user_movie_matrix.shape}")

# %%
# Calcular similitud coseno entre películas
# Transponemos para tener películas como filas
item_similarity = cosine_similarity(user_movie_matrix.T)
item_similarity_df = pd.DataFrame(
    item_similarity,
    index=user_movie_matrix.columns,
    columns=user_movie_matrix.columns
)

print("✅ Matriz de similitud calculada")

# %%
# Función de recomendación
def get_movie_recommendations(movie_title, movies_df, similarity_matrix, n_recommendations=10):
    """
    Genera recomendaciones basadas en similitud de películas
    """
    # Encontrar movieId
    movie_row = movies_df.filter(pl.col('title') == movie_title)
    
    if movie_row.height == 0:
        # Búsqueda aproximada
        movie_row = movies_df.filter(pl.col('title').str.contains(movie_title))
        if movie_row.height == 0:
            return f"Película '{movie_title}' no encontrada"
    
    movie_id = movie_row['movieId'][0]
    
    # Verificar si la película está en la matriz de similitud
    if movie_id not in similarity_matrix.columns:
        return "Película no tiene suficientes datos para recomendaciones"
    
    # Obtener películas similares
    similar_scores = similarity_matrix[movie_id].sort_values(ascending=False)[1:n_recommendations+1]
    
    # Obtener títulos
    recommendations = []
    for sim_movie_id, score in similar_scores.items():
        movie_info = movies_df.filter(pl.col('movieId') == sim_movie_id)
        if movie_info.height > 0:
            title = movie_info['title'][0]
            recommendations.append((title, score))
    
    return recommendations

# %%
# Probar el recomendador
test_movies = ['Toy Story', 'Jurassic Park', 'Forrest Gump']

for movie in test_movies:
    print(f"\n🎬 Película base: {movie}")
    print("-" * 50)
    recs = get_movie_recommendations(movie, movies, item_similarity_df, 5)
    
    if isinstance(recs, list):
        for i, (title, score) in enumerate(recs, 1):
            print(f"{i}. {title} (similitud: {score:.3f})")
    else:
        print(recs)

# %%
# Análisis de calidad del modelo
# Verificar cobertura
movies_in_matrix = set(item_similarity_df.columns)
movies_total = set(movies['movieId'].to_list())
coverage = len(movies_in_matrix) / len(movies_total) * 100

print(f"\n📊 Cobertura del modelo: {coverage:.1f}%")
print(f"Películas en modelo: {len(movies_in_matrix)} de {len(movies_total)}")

# %%
# Visualizar matriz de similitud para un grupo de películas
sample_movies = [1, 2, 3, 4, 5]  # Toy Story, Jumanji, Grumpier Old Men, etc.
sample_similarity = item_similarity_df.loc[sample_movies, sample_movies]

import seaborn as sns
import matplotlib.pyplot as plt

plt.figure(figsize=(10, 8))
sns.heatmap(sample_similarity, annot=True, cmap='coolwarm', center=0,
            xticklabels=[movies.filter(pl.col('movieId')==i)['title'][0] for i in sample_movies],
            yticklabels=[movies.filter(pl.col('movieId')==i)['title'][0] for i in sample_movies])
plt.title('Matriz de Similitud entre Películas')
plt.tight_layout()
plt.savefig('images/matriz_similitud.png')
plt.show()
